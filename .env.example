# ============================================================
# PageIndex RAG — environment variable template
# Copy this file to .env and fill in your real values.
# ============================================================

# OpenRouter (required)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-oss-20b:free
LLM_TEMPERATURE=0.2

# PageIndex cloud API (optional — falls back to local BM25 if absent)
PAGEINDEX_API_KEY=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=pageindex-rag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Tavily web search (optional — enables web search tool)
TAVILY_API_KEY=tvly-...

# Playwright browser (no key needed — uses local Chromium)
# Run: playwright install chromium
